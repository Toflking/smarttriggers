{
	"schemaVersion": 1,
	"id": "smarttriggers",
	"version": "${version}",
	"name": "SmartTriggers",
	"description": "SmartTriggers is a client-side Fabric mod that lets you create your own automation system inside Minecraft. Define rules that react to in-game text or internal state and execute actions automatically.",
	"authors": [
		"Toflking"
	],
	"contact": {
		"homepage": "https://github.com/Toflking/smarttriggers",
		"sources": "https://github.com/Toflking/smarttriggers"
	},
	"license": "MIT",
	"icon": "assets/smarttriggers/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"toflking.smarttriggers.SmartTriggersClient"
		]
	},
	"mixins": [
		"smarttriggers.mixins.json",
		{
			"config": "smarttriggers.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}
